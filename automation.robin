System.GetEnvironmentVariable.GetEnvironmentVariable Name: $'''USERPROFILE''' Value=> UserProfile
DateTime.GetCurrentDateTime.Local DateTimeFormat: DateTime.DateTimeFormat.DateAndTime CurrentDateTime=> DataExecucao
Text.ConvertDateTimeToText.FromCustomDateTime DateTime: DataExecucao CustomFormat: $'''yyyy-MM-dd_HH-mm-ss''' Result=> NomePastaExec
Folder.Create FolderPath: $'''%UserProfile%\\Desktop\\agrotrack_v2\\Execucoes''' FolderName: NomePastaExec Folder=> PastaExecucao
SET CaminhoPasta TO $'''%UserProfile%\\Desktop\\agrotrack_v2\\Execucoes\\%NomePastaExec%'''
Excel.LaunchExcel.LaunchAndOpenUnderExistingProcess Path: $'''%UserProfile%\\Desktop\\agrotrack_v2\\containers_entrada.xlsx''' Visible: True ReadOnly: False UseMachineLocale: False Instance=> ExcelEntrada
Excel.ReadFromExcel.ReadAllCells Instance: ExcelEntrada GetCellContentsMode: Excel.GetCellContentsMode.TypedValues FirstLineIsHeader: True RangeValue=> ListaContainers
Excel.CloseExcel.Close Instance: ExcelEntrada
Excel.LaunchExcel.LaunchUnderExistingProcess Visible: True UseMachineLocale: False Instance=> ExcelExecucao
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''CodigoContainer''' Column: $'''A''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''Status''' Column: $'''B''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''Modal''' Column: $'''C''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''Origem''' Column: $'''D''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''Destino''' Column: $'''E''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''ETA''' Column: $'''F''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''Produto''' Column: $'''G''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''Peso''' Column: $'''H''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''Embarque''' Column: $'''I''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''Navio''' Column: $'''J''' Row: 1
Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: $'''B/L ou CRT''' Column: $'''K''' Row: 1
WebAutomation.LaunchChrome.LaunchChrome Url: $'''https://davicarb.github.io/agrotrack_v2/web-rastreio-conteiner-agro.html''' WindowState: WebAutomation.BrowserWindowState.Normal ClearCache: False ClearCookies: False WaitForPageToLoadTimeout: 60 Timeout: 60 PiPUserDataFolderMode: WebAutomation.PiPUserDataFolderModeEnum.AutomaticProfile TargetDesktop: $'''{\"DisplayName\":\"Local computer\",\"Route\":{\"ServerType\":\"Local\",\"ServerAddress\":\"\"},\"DesktopType\":\"local\"}''' BrowserInstance=> Navegador
SET LinhaAtual TO 2
LOOP FOREACH ContainerAtual IN ListaContainers
    WebAutomation.PopulateTextField.PopulateTextFieldUsePhysicalKeyboard BrowserInstance: Navegador Control: appmask['Web Page \'h ... -agro.html\'']['Input text \'codigo\''] Text: ContainerAtual['Codigo'] Mode: WebAutomation.PopulateTextMode.Replace UnfocusAfterPopulate: True WaitForPageToLoadTimeout: 60
    WebAutomation.PressButton.PressButton BrowserInstance: Navegador Control: appmask['Web Page \'h ... -agro.html\'']['Button \'Buscar\''] WaitForPageToLoadTimeout: 60
    WAIT 1
    IF (File.IfFile.Exists File: $'''%UserProfile%\\Downloads\\agrotrack_export.json''') THEN
        File.Delete Files: $'''%UserProfile%\\Downloads\\agrotrack_export.json'''
    END
    WebAutomation.Click.Click BrowserInstance: Navegador Control: appmask['Web Page \'h ... -agro.html\'']['Anchor \'Exportar JSON\''] ClickType: WebAutomation.ClickType.LeftClick MouseClick: True WaitForPageToLoadTimeout: 60 MousePositionRelativeToElement: WebAutomation.RectangleEdgePoint.MiddleCenter OffsetX: 0 OffsetY: 0
    File.ReadTextFromFile.ReadText File: $'''%UserProfile%\\Downloads\\agrotrack_export.json''' Encoding: File.TextFileEncoding.UTF8 Content=> JSONTexto
    Variables.ConvertJsonToCustomObject Json: JSONTexto CustomObject=> DadosContainer
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['codigo'] Column: $'''A''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['statusLabel'] Column: $'''B''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['modal'] Column: $'''C''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['origem'] Column: $'''D''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['destino'] Column: $'''E''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['eta'] Column: $'''F''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['produto'] Column: $'''G''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['peso'] Column: $'''H''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['embarque'] Column: $'''I''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['navio'] Column: $'''J''' Row: LinhaAtual
    Excel.WriteToExcel.WriteCell Instance: ExcelExecucao Value: DadosContainer['bl'] Column: $'''K''' Row: LinhaAtual
    Variables.IncreaseVariable Value: LinhaAtual IncrementValue: 1
END
Excel.CloseExcel.CloseAndSaveAs Instance: ExcelExecucao DocumentFormat: Excel.ExcelFormat.OpenXmlWorkbook DocumentPath: $'''%CaminhoPasta%\\agrotrackreport_%NomePastaExec%.xlsx'''

